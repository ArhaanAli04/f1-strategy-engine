# Database (TimescaleDB — same host, same DB, TimescaleDB extension installed)
DATABASE_URL=postgresql+asyncpg://f1user:f1pass@localhost:5432/f1db
TIMESCALE_URL=postgresql+asyncpg://f1user:f1pass@localhost:5432/f1db

# Cache
REDIS_URL=redis://default:@localhost:6379

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-256-bit-random-hex-string

# FastF1 telemetry cache directory
FASTF1_CACHE_DIR=/tmp/fastf1_cache

# Observability (leave blank to disable)
SENTRY_DSN=
RELEASE_VERSION=0.1.0                # Sentry release tag — bump per deploy

# /metrics HTTP Basic Auth — defaults below match core/config.py's AppSettings
# local-dev defaults (works out of the box). Replace via GitHub Secrets on
# Day 19; must stay in sync with infra/monitoring/prometheus.yml's
# f1-backend scrape job basic_auth block.
# /metrics HTTP Basic Auth — EXAMPLE VALUES ONLY, not real credentials
# Change these in your actual .env file
METRICS_USER=metrics
METRICS_PASSWORD=metrics-dev

# Grafana admin login (localhost:3000) — local dev default, see GRAFANA_ADMIN_PASSWORD
# note in infra/docker/docker-compose.yml. Replace via GitHub Secrets on Day 19.
GRAFANA_ADMIN_PASSWORD=admin

# Alertmanager — Slack webhook URLs
SLACK_WEBHOOK_CRITICAL=              # hooks.slack.com/services/... → #alerts-critical
SLACK_WEBHOOK_WARNING=               # hooks.slack.com/services/... → #alerts-warning

# Alertmanager — PagerDuty integration key for the PodRestartsHigh alert.
# Inert until both this is set AND a Kubernetes cluster feeds
# kube-state-metrics (Day 22) — see infra/monitoring/alerts.yml.
PAGERDUTY_INTEGRATION_KEY=

# AWS S3 — model artifact storage
AWS_BUCKET_NAME=f1-strategy-models
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# Push notifications (Firebase Cloud Messaging)
FCM_SERVER_KEY=
FIREBASE_CREDENTIALS_PATH=          # path to service account JSON — never commit this file

# Runtime environment
ENVIRONMENT=development
