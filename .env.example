# Database (TimescaleDB — same host, same DB, TimescaleDB extension installed)
DATABASE_URL=postgresql+asyncpg://f1user:f1pass@localhost:5432/f1db
TIMESCALE_URL=postgresql+asyncpg://f1user:f1pass@localhost:5432/f1db

# Cache
REDIS_URL=redis://default:@localhost:6379

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-256-bit-random-hex-string

# FastF1 telemetry cache directory
FASTF1_CACHE_DIR=/tmp/fastf1_cache

# Observability (leave blank to disable)
SENTRY_DSN=

# AWS S3 — model artifact storage
AWS_BUCKET_NAME=f1-strategy-models
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# Push notifications (Firebase Cloud Messaging)
FCM_SERVER_KEY=

# Runtime environment
ENVIRONMENT=development
